# KyleClaude 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
KYLE_HOST=127.0.0.1
KYLE_PORT=7437
# Core 首次启动自动生成；不要把 KYLE_IPC_TOKEN 写入项目 .env
KYLE_IPC_TOKEN_FILE=~/.kyle/ipc-token

# ── Logging ───────────────────────────────────────────────────
KYLE_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
KYLE_LOG_FILE=~/.kyle/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
KYLE_LOG_FORMAT=text

# ── Trace（默认不记录完整 LLM 正文）─────────────────────────
KYLE_TRACE_ENABLED=true
KYLE_TRACE_INCLUDE_PAYLOAD=false
KYLE_TRACE_INCLUDE_LLM_PAYLOAD=false
KYLE_TRACE_MAX_BYTES=10485760
KYLE_TRACE_BACKUP_COUNT=5

# ── Config File ───────────────────────────────────────────────
# KYLE_CONFIG=~/.kyle/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# KYLE_LLM_PROVIDER=anthropic
# KYLE_LLM_DEFAULT_MODEL=claude-sonnet-4-6
#
# OpenAI-compatible:
# KYLE_LLM_PROVIDER=openai_compatible
# KYLE_LLM_BASE_URL=https://example.com/v1/chat/completions
# KYLE_LLM_API_KEY_ENV=KYLE_LLM_API_KEY
# KYLE_LLM_API_KEY=sk-...
# KYLE_LLM_DEFAULT_MODEL=deepseek-v4-pro
# KYLE_MAX_STEPS=20
